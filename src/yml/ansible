- name: Deploy simple web app
  hosts: web
  become: yes

  tasks:
    - name: Install Apache
      apt:
        name: apache2
        state: present
        update_cache: yes

    - name: Copy HTML file
      copy:
        src: index.html
        dest: /var/www/html/index.html
        mode: '0644'

    - name: Start Apache service
      service:
        name: apache2
        state: started
        enabled: yes
